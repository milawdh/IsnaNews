@{
    ViewData["Title"] = "Home Page";
}

<!-- This is a button toggling the modal -->
<a class="uk-button uk-button-primary" href="#modal-sections" uk-toggle>Open</a>


<div id="modal-sections" class="" uk-modal dir="rtl">
    <div class="uk-modal-dialog">
        <!--Header Start-->
        <div class="uk-modal-header _MyFont" dir="rtl">
            <button class="uk-modal-close-outside" type="button" uk-close></button>

            <h2 class="mt-2 _MyFont">
                <span uk-icon="icon:plus-circle;ratio:1.5"></span>
                <span class="uk-modal-title">
                    تبلیغ جدید
                </span>
            </h2>
        </div>
        <!--Header End-->
        <!--Body Start-->
        <div class="uk-modal-body _MyFont">
            <ul uk-tab="animation: uk-animation-fade">
                <li><a href="#" class="text-decoration-none">متن خبر</a></li>
                <li><a href="#" class="text-decoration-none">ویدئو ها</a></li>
                <li><a href="#" class="text-decoration-none">عکس های فرعی</a></li>
                <li><a href="#" class="text-decoration-none">کلمات کلیدی</a></li>
                <li><a href="#" class="text-decoration-none">نظرات خبر</a></li>
            </ul>
            <ul class="uk-switcher uk-margin">
                <!--BodyForm Start-->
                <li>
                    <form class="_MyFont" enctype="multipart/form-data" id="BodyForm" dir="rtl">

                        <div class="uk-margin">
                            <div class="uk-form-controls">
                                <div uk-form-custom class="text-end">
                                    <input required type="file" name="MainImageUrl" accept="image/png,image/jpeg,image/webp" id="MainImageUrlInput">
                                    <button class="uk-button uk-button-default" type="button">انتخاب عکس اصلی</button>
                                </div>
                                <div class="my-2 text-center" id="MainImageUrlPreview">
                                </div>
                            </div>
                        </div>

                        <div class="uk-margin">
                            <label class="uk-form-label" for="form-horizontal-text">Text</label>
                            <div class="uk-form-controls">
                                <input class="uk-input" name="Title" id="Title" type="text" placeholder="Some text...">
                            </div>
                        </div>

                        <div class="uk-margin">
                            <label class="uk-form-label" for="ReporterId">Select</label>
                            <div class="uk-form-controls">
                                <select class="uk-select" id="ReporterId" name="ReporterId">
                                    <option value="1">کاربر 1</option>
                                    <option value="2">کاربر 2</option>
                                </select>
                            </div>
                        </div>

                        <div class="uk-margin">
                            <label class="uk-form-label" for="CategoryId">Select</label>
                            <div class="uk-form-controls">
                                <select class="uk-select" id="CategoryId" name="CategoryId">
                                    <option value="1">دسته بندی 1</option>
                                    <option value="2">دسته بندی 2</option>
                                </select>
                            </div>
                        </div>

                        <div class="uk-margin">
                            <label class="_MyFont fw-bold my-1">متن خبر</label>
                            <div class="uk-form-controls">
                                <textarea class="uk-textarea" name="Body" rows="5" cols="20"></textarea>
                            </div>
                        </div>

                        <div class="uk-margin">
                            <div class="uk-form-label">نوع خبر</div>
                            <div class="uk-form-controls uk-form-controls-text">
                                <label class="_MyFont" uk-tooltip="درصورت فعال سازی خبر در کرسل صفحه اصلی نمایش داده خواهد شد">
                                    <input class="uk-radio" checked type="radio" id="IsImportantNews" name="IsImportantNews"> خبر مهم
                                </label>
                                <label class="_MyFont"><input class="uk-radio" type="radio" id="IsImportantNews" name="IsImportantNews"> خبر معمولی</label>
                            </div>
                        </div>
                    </form>
                </li>
                <!--BodyForm End-->
                <!--VideoForm Start-->
                <li>
                    <strong class="text-warning">ویدئو های قبلی</strong>
                    <div style="border:solid 2px yellow" class="p-2 my-2 rounded-2">
                        <div class="my-2">
                            <a class="bg-danger btn-close btn" uk-tooltip="حذف ویدئو"></a>
                            <video class="p-2 rounded-2 m-2" src="~/Resource/10_SlicingStrings.mp4" controls></video>
                        </div>
                        <div class="my-2">
                            <a class="bg-danger btn-close btn" uk-tooltip="حذف ویدئو"></a>
                            <video class="p-2 rounded-2 m-2" src="~/Resource/10_SlicingStrings.mp4" controls></video>
                        </div>
                        <div class="my-2">
                            <a class="bg-danger btn-close btn" uk-tooltip="حذف ویدئو"></a>
                            <video class="p-2 rounded-2 m-2" src="~/Resource/10_SlicingStrings.mp4" controls></video>
                        </div>
                        <div class="my-2">
